echo "==> Configuring Brave Browser..."

BRAVE_APP="/Applications/Brave Browser.app"
PRIVATE_DIR="${HOME}/.config/brave-private"
PRIVATE_USER_DATA="${PRIVATE_DIR}/user-data"
PRIVATE_PROFILE_DIR="${PRIVATE_USER_DATA}/Default"
EXTENSION_DIR="${PRIVATE_DIR}/extension"
ALLOWLIST_FILE="${PRIVATE_DIR}/allowlist.conf"

# ── 0. Verify Brave is installed ─────────────────────────────────────────────
if [[ ! -d "${BRAVE_APP}" ]]; then
    echo "    ⚠  Brave Browser not found — skipping configuration"
    echo "    Run 'brew install --cask brave-browser' first"
    exit 0
fi

# ── 1. Create the private instance's user-data directory ─────────────────────
#    Using a separate --user-data-dir means this runs as an entirely independent
#    Brave process. It can launch alongside your normal Brave, and startup flags
#    like --load-extension are always honoured.
mkdir -p "${PRIVATE_PROFILE_DIR}"

# ── 2. Write hardened Preferences ─────────────────────────────────────────────
echo "    → Writing hardened preferences..."

cat > "${PRIVATE_PROFILE_DIR}/Preferences" << 'PREFS_EOF'
{
  "profile": {
    "name": "Private",
    "avatar_index": 26,
    "default_content_setting_values": {
      "cookies": 4,
      "brave_fingerprinting_v2": 1,
      "brave_shields": 1
    },
    "cookie_controls_mode": 1
  },
  "brave": {
    "shields": {
      "advanced_view_enabled": true,
      "stats_badge_visible": true,
      "ads_tracking_default": "block",
      "cosmetic_filtering_default": "aggressive",
      "cookie_default": "block_third_party",
      "fingerprinting_default": "strict",
      "httpse_default": "block"
    },
    "de_amp": {
      "enabled": true
    },
    "debounce": {
