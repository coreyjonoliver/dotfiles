echo "    ✓ Hardened preferences written"

# ── 3. Configure PIA desktop VPN ─────────────────────────────────────────────
echo "    → Configuring PIA desktop VPN..."

if command -v piactl &>/dev/null; then
    piactl set killswitch always 2>/dev/null && \
        echo "    ✓ PIA kill switch set to 'always'" || \
        echo "    ⚠  Could not set PIA kill switch (is PIA running?)"
else
    echo "    ⚠  piactl not found — install PIA desktop app first"
    echo "       brew install --cask private-internet-access"
fi

# ── 4. Create the brave-private helper script ────────────────────────────────
HELPER_DIR="${HOME}/.local/bin"
HELPER="${HELPER_DIR}/brave-private"
mkdir -p "${HELPER_DIR}"

cat > "${HELPER}" << 'SCRIPT_EOF'
#!/bin/bash
# brave-private — launch a hardened, isolated Brave instance
#
# This runs Brave with its own --user-data-dir, completely separate from
# your normal Brave. It can run side-by-side with your Default Brave and
# all startup flags (--load-extension, etc.) are always honoured.
#
# Workflow:
#   1. Connects PIA desktop VPN (with kill switch)
#   2. Generates declarativeNetRequest rules from domain allowlist
#   3. Launches isolated Brave with the allowlist extension loaded
#
# Usage:
#   brave-private                  # connect VPN + launch with allowlist
#   brave-private --no-vpn         # skip VPN (allowlist still applied)
#
# Domain allowlist:
#   ~/.config/brave-private/allowlist.conf

set -euo pipefail

BRAVE="/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"
CONFIG_DIR="${HOME}/.config/brave-private"
USER_DATA_DIR="${CONFIG_DIR}/user-data"
ALLOWLIST_FILE="${CONFIG_DIR}/allowlist.conf"
EXTENSION_DIR="${CONFIG_DIR}/extension"
RULES_FILE="${EXTENSION_DIR}/rules.json"
PIA_CONNECT_TIMEOUT=30

SKIP_VPN=false
if [[ "${1:-}" == "--no-vpn" ]]; then
    SKIP_VPN=true
    shift
fi

# ── Helper functions ─────────────────────────────────────────────────────────

die() { echo "[brave-private] ✖ $1" >&2; exit 1; }
info() { echo "[brave-private] $1"; }

# ── 1. Connect PIA desktop VPN ───────────────────────────────────────────────

if [[ "${SKIP_VPN}" == "false" ]]; then
    if ! command -v piactl &>/dev/null; then
        die "piactl not found — install PIA desktop app"
    fi

    PIA_STATE=$(piactl get connectionstate 2>/dev/null || echo "unknown")

    if [[ "${PIA_STATE}" == "Connected" ]]; then
        info "PIA VPN already connected"
    else
        info "Connecting PIA VPN..."
        piactl connect || die "Failed to start PIA connection"

        ELAPSED=0
        while [[ "$(piactl get connectionstate 2>/dev/null)" != "Connected" ]]; do
            if (( ELAPSED >= PIA_CONNECT_TIMEOUT )); then
                die "PIA failed to connect within ${PIA_CONNECT_TIMEOUT}s"
            fi
            sleep 1
            ELAPSED=$(( ELAPSED + 1 ))
        done
        info "PIA VPN connected ($(piactl get vpnip 2>/dev/null || echo 'IP unknown'))"
    fi

    # Verify kill switch
    KS_STATE=$(piactl get killswitch 2>/dev/null || echo "unknown")
    if [[ "${KS_STATE}" != "always" ]]; then
        info "Setting kill switch to 'always'..."
        piactl set killswitch always 2>/dev/null || \
            info "⚠ Could not set kill switch — verify manually in PIA settings"
    fi
    info "Kill switch: $(piactl get killswitch 2>/dev/null || echo 'unknown')"
fi

# ── 2. Generate extension rules from allowlist ───────────────────────────────

if [[ ! -f "${ALLOWLIST_FILE}" ]]; then
    die "Allowlist not found: ${ALLOWLIST_FILE}"
fi

if [[ ! -f "${EXTENSION_DIR}/manifest.json" ]]; then
    die "Extension not found: ${EXTENSION_DIR}/manifest.json"
fi

# Parse allowlist: strip comments and blank lines
DOMAINS=()
while IFS= read -r line; do
    line="${line%%#*}"        # strip inline comments
    line="${line// /}"        # strip whitespace
    [[ -z "${line}" ]] && continue
    DOMAINS+=("${line}")
done < "${ALLOWLIST_FILE}"

if (( ${#DOMAINS[@]} == 0 )); then
    die "Allowlist is empty — refusing to launch with no permitted domains"
fi

info "Building extension rules (${#DOMAINS[@]} domains)..."

# Generate rules.json for declarativeNetRequest:
#   Rule 1 (priority 1): Block all main_frame and sub_frame navigations
#   Rules 2+N (priority 2): Allow navigation to allowlisted domains + subdomains
#
# Only main_frame and sub_frame are restricted. Sub-resources (scripts, images,
# CSS, XHR) are permitted so that allowed pages can load assets from CDNs.

python3 - "${RULES_FILE}" "${DOMAINS[@]}" << 'PYGEN'
import json, sys

rules_path = sys.argv[1]
domains = sys.argv[2:]

rules = [
    {
        "id": 1,
        "priority": 1,
        "action": {"type": "block"},
        "condition": {
            "resourceTypes": ["main_frame", "sub_frame"]
        }
    }
]

for i, domain in enumerate(domains):
    rules.append({
        "id": i + 2,
        "priority": 2,
        "action": {"type": "allow"},
        "condition": {
            "requestDomains": [domain],
            "resourceTypes": ["main_frame", "sub_frame"]
        }
    })

with open(rules_path, "w") as f:
    json.dump(rules, f, indent=2)

print(f"    Generated {len(rules)} rules ({len(domains)} allowed domains)")
PYGEN

# ── 3. Launch Brave ──────────────────────────────────────────────────────────

info "Launching Brave (Private instance)..."

# --user-data-dir  → separate Brave process, independent of your normal Brave
# --load-extension → loads allowlist extension (works because own process)
# --no-first-run   → skip welcome flow on first launch
"${BRAVE}" \
    --user-data-dir="${USER_DATA_DIR}" \
    --load-extension="${EXTENSION_DIR}" \
    --no-first-run \
    --no-default-browser-check \
    "$@" &>/dev/null &

info "Brave launched (PID $!)"
SCRIPT_EOF

chmod +x "${HELPER}"
echo "    ✓ brave-private helper installed to ${HELPER}"

# ── 5. Print summary and manual steps ────────────────────────────────────────

