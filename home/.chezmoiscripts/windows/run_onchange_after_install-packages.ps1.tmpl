{{ if eq .chezmoi.os "windows" -}}
#Requires -Version 5.1
Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

# packages.toml hash: {{ include ".chezmoidata/packages.toml" | sha256sum }}

Write-Host "==> Installing Windows packages..."

if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
    Write-Host "    ⚠  winget not found — install App Installer from the Microsoft Store"
    exit 0
}

$packages = @(
{{- range .windows.winget.packages }}
    {{ . | quote }}
{{- end }}
)

foreach ($pkg in $packages) {
    $installed = winget list --exact --id $pkg 2>$null
    if ($LASTEXITCODE -eq 0 -and $installed -match $pkg) {
        Write-Host "    ✓ $pkg already installed"
    } else {
        Write-Host "    → Installing $pkg..."
        winget install -e --id $pkg --accept-package-agreements --accept-source-agreements
    }
}

Write-Host "==> Package installation complete"
{{ end -}}
